  "meta": {
    "industry_id": "telecom",
    "industry_name": "通信",
    "version": "0.1.0",
    "updated": "2026-07-23",
    "description": "通信業界の商流。キャリアを中心に、契約者の通信料、MVNOへの回線卸、基地局への設備投資、電波利用料という金流を描く。国から周波数の割当を受けるという参入障壁が構造の核。",
    "tagline": "月額料金の裏にある、電波・基地局・回線卸のインフラ経済",
    "editorial_note": "v1は公開情報ベース。financialsは概算でIR確定値へ差し替え前提。NTTドコモはNTT(9432)の完全子会社のため財務はNTT連結で表示。",
    "guide": {
      "earn": "キャリアは月額通信料(OPEX)の積み上げで稼ぎ、基地局・光ファイバー網へ継続的に設備投資する。周波数は国からの割当で、MVNOへの回線卸も収益源。",
      "watch": "消費者→キャリア→設備ベンダーという金流に加え、キャリア→MVNOの回線卸エッジが価格競争の構造を説明してくれる。"
    },
    "journey": {
      "title": "スマホ代・月5,000円の旅",
      "steps": [
        {
          "edge": "opex_subscriber_carrier",
          "say": "毎月引き落とされる5,000円。この安定収入の積み上げが、キャリアを日本有数の高収益企業にしている。"
        },
        {
          "edge": "capex_carrier_vendor",
          "say": "そのカネの一部は基地局設備へ。5G網は数年がかり・兆円級の設備投資でできている。"
        },
        {
          "edge": "capex_carrier_construction",
          "say": "基地局を実際に建てるのは通信建設会社。鉄塔からビルの屋上まで、全国で工事が続く。"
        },
        {
          "edge": "opex_carrier_device",
          "say": "店頭に並ぶスマホ本体も、キャリアがメーカーから仕入れている。端末値引きの原資も通信料だ。"
        },
        {
          "edge": "opex_carrier_mic",
          "say": "電波はタダではない。キャリアは国に電波利用料を払い、周波数の割当を受けている。"
        },
        {
          "edge": "opex_mvno_carrier",
          "say": "格安SIMを使っていても無関係ではない。MVNOの料金の一部は回線卸料金として大手キャリアに流れ込む。"
        }
      ]
    }
  },
